  "keyFeatures": [
    "Multi-stage Docker builds for development and production environments",
    "Kubernetes orchestration with Helm chart management",
    "Infrastructure as Code using Terraform for Vercel deployments",
    "Automated CI/CD pipelines with GitHub Actions",
    "Turborepo monorepo architecture with shared packages",
    "Supabase integration for authentication and database",
    "High availability with 3-replica Kubernetes deployments",
    "Ingress controller configuration for external access"
  ],
  "publicApiSurface": [
    "docker build -f Dockerfile.dev",
    "docker compose up",
    "helm upgrade --install nexushotel",
    "kubectl get all -n nexushotel",
    "terraform init",
    "terraform apply",
